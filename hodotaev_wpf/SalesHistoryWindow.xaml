<Window x:Class="hodotaev_wpf.SalesHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:hodotaev_wpf"
        mc:Ignorable="d"
        Title="История продаж" 
        Height="500" Width="800"
        WindowStartupLocation="CenterOwner">
    
    <Window.Resources>
        <!-- Стили для заголовков -->
        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        
        <!-- Стили для информационного блока -->
        <Style x:Key="InfoStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="5,2"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="История реализации продукции партнером" 
                   Style="{StaticResource HeaderStyle}"/>
        
        <!-- Информация о партнере -->
        <Border Grid.Row="1" 
                BorderBrush="Gray" 
                BorderThickness="1" 
                CornerRadius="3"
                Padding="10"
                Margin="0,0,0,10"
                Background="#f9f9f9">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Grid.Column="0" 
                           x:Name="txtCompanyName"
                           Style="{StaticResource InfoStyle}"
                           FontWeight="Bold"/>
                <TextBlock Grid.Row="0" Grid.Column="1" 
                           x:Name="txtPartnerType"
                           Style="{StaticResource InfoStyle}"/>
                
                <TextBlock Grid.Row="1" Grid.Column="0" 
                           x:Name="txtDirector"
                           Style="{StaticResource InfoStyle}"/>
                <TextBlock Grid.Row="1" Grid.Column="1" 
                           x:Name="txtPhone"
                           Style="{StaticResource InfoStyle}"/>
                
                <TextBlock Grid.Row="2" Grid.Column="0" 
                           x:Name="txtEmail"
                           Style="{StaticResource InfoStyle}"/>
                <TextBlock Grid.Row="2" Grid.Column="1" 
                           x:Name="txtRating"
                           Style="{StaticResource InfoStyle}"/>
                
                <TextBlock Grid.Row="3" Grid.Column="0" 
                           x:Name="txtTotalSales"
                           Style="{StaticResource InfoStyle}"
                           FontWeight="Bold"
                           Foreground="#0066cc"/>
            </Grid>
        </Border>
        
        <!-- Таблица истории продаж -->
        <DataGrid x:Name="dgSales"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  BorderBrush="Gray"
                  BorderThickness="1"
                  SelectionChanged="dgSales_SelectionChanged">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Padding" Value="8,5"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Background" Value="#f0f0f0"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="8,5"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#cce8ff"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="№" Binding="{Binding SaleId}" Width="50"/>
                <DataGridTextColumn Header="Дата продажи" Binding="{Binding SaleDate, StringFormat={}{0:dd.MM.yyyy}}" Width="100"/>
                <DataGridTextColumn Header="Продукция" Binding="{Binding Product.ProductName}" Width="200"/>
                <DataGridTextColumn Header="Артикул" Binding="{Binding Product.Article}" Width="100"/>
                <DataGridTextColumn Header="Количество" Binding="{Binding Quantity}" Width="80"/>
                <DataGridTextColumn Header="Ед. изм." Binding="{Binding Product.Unit}" Width="70"/>
                <DataGridTextColumn Header="Цена за ед." Binding="{Binding SalePrice, StringFormat={}{0:N2}}" Width="100"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding TotalAmount, StringFormat={}{0:N2}}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button x:Name="btnAddSale"
                    Content="_Добавить продажу"
                    Click="btnAddSale_Click"
                    Padding="15,8"
                    Margin="0,0,10,0"/>
            <Button x:Name="btnEditSale"
                    Content="_Редактировать"
                    Click="btnEditSale_Click"
                    Padding="15,8"
                    Margin="0,0,10,0"/>
            <Button x:Name="btnDeleteSale"
                    Content="_Удалить"
                    Click="btnDeleteSale_Click"
                    Padding="15,8"
                    Margin="0,0,10,0"/>
            <Button x:Name="btnClose"
                    Content="_Закрыть"
                    Click="btnClose_Click"
                    Padding="20,8"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
