<Window x:Class="hodotaev_wpf.PartnerEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:hodotaev_wpf"
        mc:Ignorable="d"
        Title="Редактирование партнера" 
        Height="500" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    
    <Window.Resources>
        <!-- Стили для лейблов -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,5,10,5"/>
        </Style>
        
        <!-- Стили для полей ввода -->
        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Padding" Value="5"/>
        </Style>
        
        <!-- Стили для кнопок -->
        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Margin" Value="5,10,5,5"/>
            <Setter Property="MinWidth" Value="80"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Форма -->
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Наименование компании -->
            <TextBlock Grid.Row="0" Grid.Column="0" 
                       Text="Наименование компании:" 
                       Style="{StaticResource LabelStyle}"/>
            <TextBox Grid.Row="0" Grid.Column="1" 
                     x:Name="txtCompanyName"
                     Style="{StaticResource TextBoxStyle}"/>
            
            <!-- Тип партнера -->
            <TextBlock Grid.Row="1" Grid.Column="0" 
                       Text="Тип партнера:" 
                       Style="{StaticResource LabelStyle}"/>
            <ComboBox Grid.Row="1" Grid.Column="1" 
                      x:Name="cmbPartnerType"
                      DisplayMemberPath="TypeName"
                      SelectedValuePath="PartnerTypeId"
                      Margin="0,5"/>
            
            <!-- Рейтинг -->
            <TextBlock Grid.Row="2" Grid.Column="0" 
                       Text="Рейтинг:" 
                       Style="{StaticResource LabelStyle}"/>
            <TextBox Grid.Row="2" Grid.Column="1" 
                     x:Name="txtRating"
                     Style="{StaticResource TextBoxStyle}"
                     Text="0"/>
            
            <!-- Адрес -->
            <TextBlock Grid.Row="3" Grid.Column="0" 
                       Text="Юридический адрес:" 
                       Style="{StaticResource LabelStyle}"/>
            <TextBox Grid.Row="3" Grid.Column="1" 
                     x:Name="txtLegalAddress"
                     Style="{StaticResource TextBoxStyle}"/>
            
            <!-- ИНН -->
            <TextBlock Grid.Row="4" Grid.Column="0" 
                       Text="ИНН:" 
                       Style="{StaticResource LabelStyle}"/>
            <TextBox Grid.Row="4" Grid.Column="1" 
                     x:Name="txtInn"
                     Style="{StaticResource TextBoxStyle}"/>
            
            <!-- ФИО директора -->
            <TextBlock Grid.Row="5" Grid.Column="0" 
                       Text="ФИО директора:" 
                       Style="{StaticResource LabelStyle}"/>
            <TextBox Grid.Row="5" Grid.Column="1" 
                     x:Name="txtDirectorFullName"
                     Style="{StaticResource TextBoxStyle}"/>
            
            <!-- Телефон -->
            <TextBlock Grid.Row="6" Grid.Column="0" 
                       Text="Телефон:" 
                       Style="{StaticResource LabelStyle}"/>
            <TextBox Grid.Row="6" Grid.Column="1" 
                     x:Name="txtPhone"
                     Style="{StaticResource TextBoxStyle}"/>
            
            <!-- Email -->
            <TextBlock Grid.Row="7" Grid.Column="0" 
                       Text="Email:" 
                       Style="{StaticResource LabelStyle}"/>
            <TextBox Grid.Row="7" Grid.Column="1" 
                     x:Name="txtEmail"
                     Style="{StaticResource TextBoxStyle}"/>
        </Grid>
        
        <!-- Кнопки -->
        <StackPanel Grid.Row="1" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right">
            <Button x:Name="btnSave" 
                    Content="_Сохранить" 
                    Click="btnSave_Click"
                    Style="{StaticResource DialogButtonStyle}"
                    IsDefault="True"/>
            <Button x:Name="btnCancel" 
                    Content="О_тмена" 
                    Click="btnCancel_Click"
                    Style="{StaticResource DialogButtonStyle}"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
