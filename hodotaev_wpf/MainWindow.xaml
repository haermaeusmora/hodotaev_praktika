<Window x:Class="hodotaev_wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:hodotaev_wpf"
        mc:Ignorable="d"
        Title="Подсистема работы с партнерами - Мастер Пол" 
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <!-- Стили для кнопок -->
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="MinWidth" Value="100"/>
        </Style>
        
        <!-- Стили для информационных блоков -->
        <Style x:Key="InfoStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="5,3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        
        <!-- Стили для карточки партнера -->
        <Style x:Key="PartnerCardStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="Gray"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="#f9f9f9"/>
        </Style>
        
        <!-- Стили для элементов списка -->
        <Style x:Key="ListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" 
                                Padding="5" 
                                BorderBrush="#ddd" 
                                BorderThickness="0,0,0,1"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#cce8ff"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#e6f3ff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="Управление партнерами" 
                   FontSize="20" 
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>
        
        <!-- Панель инструментов -->
        <StackPanel Grid.Row="1" 
                    Orientation="Horizontal" 
                    Margin="0,0,0,10">
            <Button x:Name="btnAdd" 
                    Content="_Добавить" 
                    Click="btnAdd_Click"
                    Style="{StaticResource MenuButtonStyle}"/>
            <Button x:Name="btnEdit" 
                    Content="_Редактировать" 
                    Click="btnEdit_Click"
                    Style="{StaticResource MenuButtonStyle}"/>
            <Button x:Name="btnDelete" 
                    Content="_Удалить" 
                    Click="btnDelete_Click"
                    Style="{StaticResource MenuButtonStyle}"/>
            <Button x:Name="btnHistory" 
                    Content="И_стория продаж" 
                    Click="btnHistory_Click"
                    Style="{StaticResource MenuButtonStyle}"/>
            <Button x:Name="btnRefresh" 
                    Content="_Обновить" 
                    Click="btnRefresh_Click"
                    Style="{StaticResource MenuButtonStyle}"/>
            <Button x:Name="btnExit" 
                    Content="В_ыход" 
                    Click="btnExit_Click"
                    Style="{StaticResource MenuButtonStyle}"
                    HorizontalAlignment="Right"/>
        </StackPanel>
        
        <!-- Список партнеров -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Список слева -->
            <Border Grid.Column="0" 
                    BorderBrush="Gray" 
                    BorderThickness="1" 
                    CornerRadius="3"
                    Background="White">
                <ListBox x:Name="lstPartners" 
                         SelectionChanged="lstPartners_SelectionChanged"
                         MouseDoubleClick="lstPartners_MouseDoubleClick"
                         ItemContainerStyle="{StaticResource ListBoxItemStyle}"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="5">
                                <TextBlock Text="{Binding CompanyName}" 
                                           FontWeight="Bold" 
                                           FontSize="14"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding PartnerType.TypeName}" 
                                           FontSize="11"
                                           Foreground="#666"/>
                                <TextBlock FontSize="11">
                                    <Run Text="Рейтинг: "/>
                                    <Run Text="{Binding Rating}" FontWeight="Bold"/>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
            
            <!-- Карточка партнера справа -->
            <Border Grid.Column="1" 
                    BorderBrush="Gray" 
                    BorderThickness="1" 
                    CornerRadius="3"
                    Padding="15"
                    Margin="10,0,0,0"
                    Background="#f9f9f9"
                    VerticalAlignment="Top">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Заголовок карточки -->
                    <TextBlock Grid.Row="0" 
                               x:Name="txtCardTitle"
                               Text="Информация о партнере"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>
                    
                    <!-- Основная информация -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Компания -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,3">
                            <TextBlock Text="Компания:" FontWeight="Bold" FontSize="12" Foreground="#666"/>
                            <TextBlock x:Name="txtCompanyName" 
                                       FontSize="14"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        
                        <!-- Тип партнера -->
                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,3">
                            <TextBlock Text="Тип партнера:" FontWeight="Bold" FontSize="12" Foreground="#666"/>
                            <TextBlock x:Name="txtPartnerType" FontSize="14"/>
                        </StackPanel>
                        
                        <!-- Директор -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,3">
                            <TextBlock Text="Директор:" FontWeight="Bold" FontSize="12" Foreground="#666"/>
                            <TextBlock x:Name="txtDirector" FontSize="14"/>
                        </StackPanel>
                        
                        <!-- Телефон -->
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,3">
                            <TextBlock Text="Телефон:" FontWeight="Bold" FontSize="12" Foreground="#666"/>
                            <TextBlock x:Name="txtPhone" FontSize="14"/>
                        </StackPanel>
                        
                        <!-- Email -->
                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,3">
                            <TextBlock Text="Email:" FontWeight="Bold" FontSize="12" Foreground="#666"/>
                            <TextBlock x:Name="txtEmail" FontSize="14"/>
                        </StackPanel>
                        
                        <!-- Рейтинг -->
                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,3">
                            <TextBlock Text="Рейтинг:" FontWeight="Bold" FontSize="12" Foreground="#666"/>
                            <TextBlock x:Name="txtRating" FontSize="14"/>
                        </StackPanel>
                        
                        <!-- Адрес -->
                        <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,3">
                            <TextBlock Text="Адрес:" FontWeight="Bold" FontSize="12" Foreground="#666"/>
                            <TextBlock x:Name="txtAddress" 
                                       FontSize="14"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        
                        <!-- ИНН -->
                        <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,3">
                            <TextBlock Text="ИНН:" FontWeight="Bold" FontSize="12" Foreground="#666"/>
                            <TextBlock x:Name="txtInn" FontSize="14"/>
                        </StackPanel>
                    </Grid>
                    
                    <!-- Информация о продажах -->
                    <Border Grid.Row="2" 
                            Margin="0,10,0,0"
                            Padding="10"
                            Background="#e6f3ff"
                            CornerRadius="3">
                        <StackPanel>
                            <TextBlock Text="Статистика продаж" 
                                       FontWeight="Bold" 
                                       FontSize="14"
                                       Margin="0,0,0,5"/>
                            <TextBlock x:Name="txtTotalSales" 
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Foreground="#0066cc"/>
                            <TextBlock x:Name="txtDiscount" 
                                       FontSize="13"
                                       Foreground="#008800"
                                       Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
        
        <!-- Статус бар -->
        <StatusBar Grid.Row="3" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock x:Name="txtStatus" Text="Готов к работе"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="txtCount" Text="Партнеров: 0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
